WORKING_DIR=/workspace
SPLENT_APP=diversolab_app
PYTHONPATH=/workspace/diversolab_app/src
FLASK_APP=diversolab_app:create_app

MARIADB_HOSTNAME=diversolab_app_db
MARIADB_DATABASE=diversolab_app_db
